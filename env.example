# StratOS Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (required)
# Get from: supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Function Secrets - set these via Supabase Dashboard or CLI:
# npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# npx supabase secrets set TWELVE_DATA_API_KEY=your-key
# npx supabase secrets set FINNHUB_API_KEY=your-key
